# ── Required ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://church:yourpassword@localhost:5432/church_portal

# Server port (default: 3000 in production)
PORT=3000

# ── Optional ───────────────────────────────────────────────────────────────────

# CORS allowed origin (set to your domain in production)
# Leave empty or "true" to allow all origins during dev
CORS_ORIGIN=https://yourdomain.com

# Node environment
NODE_ENV=production

# ── docker-compose only ────────────────────────────────────────────────────────
# Only needed if using the bundled postgres container
POSTGRES_USER=church
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=church_portal
