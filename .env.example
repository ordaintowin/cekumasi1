# ── Required ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway/Fly.io inject this automatically)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://church:yourpassword@localhost:5432/church_portal

# Secret key for signing JWTs — use a long random string (32+ characters)
JWT_SECRET=change-me-to-a-long-random-string

# Server port (Railway sets this automatically)
PORT=3000

# ── Optional ───────────────────────────────────────────────────────────────────

# CORS allowed origin — set to your domain in production
CORS_ORIGIN=https://your-app.railway.app

# Node environment
NODE_ENV=production
